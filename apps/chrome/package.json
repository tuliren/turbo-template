{
  "name": "@repo/chrome-ext",
  "version": "0.0.1",
  "description": "Chrome extension template with side panel, options, and content-script messaging",
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "build:storybook": "storybook build",
    "build-dev": "yarn clean && webpack --config webpack/webpack.dev.js",
    "build-prod": "yarn clean && webpack --config webpack/webpack.prod.js",
    "clean": "rimraf dist",
    "dev": "webpack --config webpack/webpack.dev.js --watch",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "format:write": "prettier --write \"src/**/*.{ts,tsx}\"",
    "lint": "eslint . --max-warnings 0",
    "storybook": "storybook dev -p 6006",
    "test": "jest --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit --p tsconfig.json"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@chromatic-com/storybook": "^5.1.2",
    "@repo/eslint-config": "*",
    "@repo/jest-presets": "*",
    "@repo/typescript-config": "*",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-links": "^10.3.6",
    "@storybook/react": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/babel__core": "^7.20.5",
    "@types/babel__preset-env": "^7.10.0",
    "@types/chrome": "^0.1.42",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-loader": "^10.1.1",
    "babel-plugin-react-require": "^4.0.2",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "dotenv": "^17.4.2",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-storybook": "^10.3.6",
    "glob": "^13.0.6",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-html-reporter": "^4.4.0",
    "postcss": "^8.5.14",
    "postcss-loader": "^8.2.1",
    "rimraf": "^6.1.3",
    "storybook": "^10.3.6",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "typescript": "^5.9.3",
    "vite": "^8.0.12",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-merge": "^6.0.1"
  }
}
