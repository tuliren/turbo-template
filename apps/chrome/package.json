{
  "name": "@repo/chrome-ext",
  "version": "0.0.1",
  "description": "Chrome extension template with side panel, options, and content-script messaging",
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "build-dev": "yarn clean && webpack --config webpack/webpack.dev.js",
    "build-prod": "yarn clean && webpack --config webpack/webpack.prod.js",
    "build:storybook": "storybook build",
    "clean": "rimraf dist",
    "dev": "webpack --config webpack/webpack.dev.js --watch",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "format:write": "prettier --write \"src/**/*.{ts,tsx}\"",
    "lint": "eslint . --max-warnings 0",
    "storybook": "storybook dev -p 6006",
    "test": "jest --coverage",
    "typecheck": "tsc --noEmit --p tsconfig.json"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.0.12",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.0.12",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@babel/preset-env": "^7.25.3",
    "@babel/preset-react": "^7.24.7",
    "@babel/preset-typescript": "^7.24.7",
    "@chromatic-com/storybook": "^1.6.0",
    "@repo/eslint-config": "*",
    "@repo/jest-presets": "*",
    "@repo/typescript-config": "*",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-interactions": "^8.4.7",
    "@storybook/addon-links": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/react": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@storybook/test": "^8.4.7",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/babel__core": "^7",
    "@types/babel__preset-env": "^7",
    "@types/chrome": "^0.0.268",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.5.2",
    "@types/react": "^18.0.29",
    "@types/react-dom": "^18.0.11",
    "@types/turndown": "^5.0.4",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-loader": "^9.1.3",
    "babel-plugin-react-require": "^4.0.2",
    "copy-webpack-plugin": "^9.0.1",
    "css-loader": "^7.1.2",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^28.6.0",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-storybook": "^0.8.0",
    "glob": "^7.1.6",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-html-reporter": "^3.10.2",
    "postcss": "^8.4.39",
    "postcss-loader": "^8.1.1",
    "react-require": "^1.0.1",
    "rimraf": "^3.0.2 ",
    "storybook": "^8.4.7",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.1.0",
